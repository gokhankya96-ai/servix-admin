# Teknik Servis Production Ortam Örneği
# Bu dosyayı .env olarak kopyalayıp kendi değerlerinle doldurabilirsin.
# Uygulama mevcut haliyle ayarları SQLite üzerinden yönetir; bu dosya dağıtım notu amaçlıdır.

APP_NAME=Teknik Servis
APP_VERSION=1.0.0
UPDATE_SERVER_URL=https://senin-domainin.com/updates/

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mail@domain.com
SMTP_FROM=mail@domain.com
SMTP_PASSWORD=app-password

BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_KEEP_COUNT=10

# Servix Auto Update / GitHub Releases
GH_TOKEN=github_token_buraya
GITHUB_OWNER=CHANGE_ME_GITHUB_OWNER
GITHUB_REPO=servix-releases
SERVIX_RELEASE_CHANNEL=stable
